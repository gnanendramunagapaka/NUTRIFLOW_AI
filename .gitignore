# ============================================================
# NutriFlow AI — .gitignore
# ============================================================

# ─── Environment Variables & Secrets ──────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
*.env

# ─── Dependencies ─────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build Output ─────────────────────────────────────────
dist/
dist-ssr/
build/
out/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared

# ─── Temporary / Debug ────────────────────────────────────
tmp/
temp/
.tmp/
*.log
npm-debug.log*
yarn-error.log
pnpm-debug.log*

# ─── Database Temp (local PostgreSQL instance) ────────────
db-temp/

# ─── IDEs & Editors ───────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ─── System Files ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# ─── Replit Specific ──────────────────────────────────────
.cache/
.local/
.agents/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
.replitignore
.replit
.replit-artifact/

# ─── Lock files (keep pnpm-lock.yaml, ignore npm/yarn) ───
package-lock.json
yarn.lock

# ─── Misc ─────────────────────────────────────────────────
/coverage
*.orig
*.rej
